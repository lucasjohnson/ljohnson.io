    "@mui/material-nextjs": "^7.3.8",
    "@mui/x-data-grid": "^8.27.3",
    "@supabase/supabase-js": "^2.98.0",
    "@tommyvez/passfort": "^1.0.1",
    "docx": "^9.6.0",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "pdfkit": "^0.17.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
